# Edge Function Environment Variables (set in Supabase Dashboard)
# GOOGLE_API_KEY=        # Gemini API (card news, short-form, ad copy, ad creative, thumbnail, trend analysis)
# OPENAI_API_KEY=        # OpenAI TTS fallback
# ELEVENLABS_API_KEY=    # ElevenLabs TTS (primary)
# REPLICATE_API_TOKEN=   # Replicate I2V (Wan 2.5, Hailuo, Kling)
# UNSPLASH_ACCESS_KEY=   # Unsplash stock image search
# PEXELS_API_KEY=        # Pexels stock image search (fallback)
# APIFY_API_TOKEN=       # Apify X trending scraper
# JAMENDO_CLIENT_ID=     # Jamendo royalty-free BGM search
